vals <- values(r2, na.rm = TRUE)
message(sprintf("Value range: %.1f to %.1f  (0 = least deprived, 100 = most)",
min(vals), max(vals)))
# how many cells inside Kenya have a GRDI value?
n_data <- global(!is.na(r2), "sum", na.rm = TRUE)[[1]]
# how many cells inside Kenya total? (mask a constant raster instead of an empty one)
tmp    <- setValues(rast(r2), 1)          # same grid, all 1s
tmp    <- mask(tmp, ken_v)
n_kenya <- global(!is.na(tmp), "sum", na.rm = TRUE)[[1]]
cat(sprintf("GRDI covers %.1f%% of Kenya's cells (%d of %d)\n",
100 * n_data / n_kenya, n_data, n_kenya))
# what does the file declare as NoData?
NAflag(rast(grdi_file))
# 6. Save + plot
