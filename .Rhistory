## UV data
nc_file   <- "data/uvddc2024_msr_world.nc"
gpkg_file <- "backend/vectorData/ken_county.gpkg"
nc_var    <- NA
out_tif   <- "kenya_uv_2024.tif"
# 1. Kenya boundary + bounding box (in lon/lat)
ken  <- st_read(gpkg_file, quiet = TRUE)
ken
plot(ken)
ken  <- st_transform(ken, 4326)
ken_v <- vect(ken)
bb   <- ext(ken_v)
message(sprintf("Kenya bbox: %.2f, %.2f, %.2f, %.2f",
bb$xmin, bb$xmax, bb$ymin, bb$ymax))
# 2. Open the NetCDF as a (possibly multi-layer) raster
if (is.na(nc_var)) {
r <- rast(nc_file)                      # terra picks the variable(s)
} else {
r <- rast(nc_file, subds = nc_var)
}
message(sprintf("Loaded '%s' with %d layer(s)", nc_file, nlyr(r)))
# make sure it carries a lon/lat CRS
if (is.na(crs(r)) || crs(r) == "") crs(r) <- "EPSG:4326"
# 3. CROP to Kenya's bbox FIRST — this is the key speed/memory step
r <- crop(r, bb)
message(sprintf("Cropped to %d x %d cells", nrow(r), ncol(r)))
# 4. Collapse time to an annual mean if there are many layers
if (nlyr(r) > 1) {
r <- mean(r, na.rm = TRUE)
message("Averaged multiple layers -> single annual-mean layer")
}
# 5. Mask to Kenya's exact shape (cells outside the border -> NA)
r <- mask(r, ken_v)
plot(r)
rm(r)
# 2. Open the NetCDF as a (possibly multi-layer) raster
if (is.na(nc_var)) {
r <- rast(nc_file)                      # terra picks the variable(s)
} else {
r <- rast(nc_file, subds = nc_var)
}
message(sprintf("Loaded '%s' with %d layer(s)", nc_file, nlyr(r)))
# make sure it carries a lon/lat CRS
if (is.na(crs(r)) || crs(r) == "") crs(r) <- "EPSG:4326"
# 3. CROP to Kenya's bbox FIRST — this is the key speed/memory step
r <- crop(r, bb)
message(sprintf("Cropped to %d x %d cells", nrow(r), ncol(r)))
# 4. Collapse time to an annual mean if there are many layers
if (nlyr(r) > 1) {
r <- mean(r, na.rm = TRUE)
message("Averaged multiple layers -> single annual-mean layer")
}
# 5. Mask to Kenya's exact shape (cells outside the border -> NA)
r <- disagg(r, fact = 10, method = "bilinear")
r <- mask(r, ken_v)
plot(r)
# 6. Save + quick look
writeRaster(r, out_tif, overwrite = TRUE)
message(sprintf("Wrote %s", out_tif))
plot(r, main = "Kenya — cropped & masked")
plot(st_geometry(ken), add = TRUE, border = "grey30", lwd = 0.4)
plot(st_geometry(ken), add = TRUE, border = "white", lwd = 0.4)
## PM data
nc_file1   <- "data/V6GL02.04.CNNPM25.GL.202301-202312.nc"                 # your NetCDF
gpkg_file <- "backend/vectorData/ken_county.gpkg"          # Kenya boundary
nc_var    <- NA          # variable name, or NA to auto-pick the first
out_tif1   <- "kenya_pm_2024.tif"                           # output GeoTIFF
message(sprintf("Kenya bbox: %.2f, %.2f, %.2f, %.2f",
bb$xmin, bb$xmax, bb$ymin, bb$ymax))
# 2. Open the NetCDF as a (possibly multi-layer) raster
if (is.na(nc_var)) {
r <- rast(nc_file1)                      # terra picks the variable(s)
} else {
r <- rast(nc_file1, subds = nc_var)
}
rm(r)
# 2. Open the NetCDF as a (possibly multi-layer) raster
if (is.na(nc_var)) {
r1 <- rast(nc_file1)                      # terra picks the variable(s)
} else {
r1 <- rast(nc_file1, subds = nc_var)
}
message(sprintf("Loaded '%s' with %d layer(s)", nc_file1, nlyr(r1)))
# make sure it carries a lon/lat CRS
if (is.na(crs(r1)) || crs(r1) == "") crs(r1) <- "EPSG:4326"
# 3. CROP to Kenya's bbox FIRST — this is the key speed/memory step
r1 <- crop(r1, bb)
message(sprintf("Cropped to %d x %d cells", nrow(r1), ncol(r1)))
# 4. Collapse time to an annual mean if there are many layers
if (nlyr(r1) > 1) {
r1 <- mean(r1, na.rm = TRUE)
message("Averaged multiple layers -> single annual-mean layer")
}
# 5. Mask to Kenya's exact shape (cells outside the border -> NA)
r1 <- mask(r1, ken_v)
plot(r1)
# 6. Save + quick look
writeRaster(r1, out_tif1, overwrite = TRUE)
message(sprintf("Wrote %s", out_tif1))
plot(r1, main = "Kenya — cropped & masked")
plot(st_geometry(ken), add = TRUE, border = "grey30", lwd = 0.4)
grdi_file <- "/Users/cema/Downloads/povmap-grdi-v1-geotiff/povmap-grdi-v1.tif"
gpkg_file <- "backend/vectorData/ken_county.gpkg"
grdi_file <- "/Users/cema/Downloads/povmap-grdi-v1-geotiff/povmap-grdi-v1.tif"
grdi_file
# 1. Kenya boundary + bbox
ken   <- st_transform(st_read(gpkg_file, quiet = TRUE), 4326)
ken_v <- vect(ken)
bb    <- ext(ken_v)
message(sprintf("Kenya bbox: %.2f, %.2f, %.2f, %.2f",
bb$xmin, bb$xmax, bb$ymin, bb$ymax))
# 2. Open GRDI (global ~1 km raster — do NOT load it all into memory)
r2 <- rast(grdi_file)
if (is.na(crs(r2)) || crs(r2) == "") crs(r2) <- "EPSG:4326"
message(sprintf("GRDI opened: %d x %d, res %.4f deg", nrow(r2), ncol(r2), res(r2)[1]))
# 3. CROP to Kenya's bbox FIRST (fast, low memory — terra reads only this window)
r2 <- crop(r2, bb)
message(sprintf("Cropped to %d x %d cells", nrow(r2), ncol(r2)))
# 4. Mask to Kenya's exact shape (outside -> NA)
r2 <- mask(r2, ken_v)
plot(r2)
# 5. Sanity check: GRDI should span roughly 0-100
vals <- values(r, na.rm = TRUE)
# 5. Sanity check: GRDI should span roughly 0-100
vals <- values(r2, na.rm = TRUE)
message(sprintf("Value range: %.1f to %.1f  (0 = least deprived, 100 = most)",
min(vals), max(vals)))
plot(st_geometry(ken), add = TRUE, border = "grey30", lwd = 0.4)
# what fraction of Kenya has data?
sum(!is.na(values(r2))) / sum(!is.na(values(mask(rast(ext(r2), resolution=res(r2)), ken_v))))
# what does the file declare as NoData?
NAflag(rast(grdi_file))
# how many cells inside Kenya have a GRDI value?
n_data <- global(!is.na(r2), "sum", na.rm = TRUE)[[1]]
# how many cells inside Kenya total? (mask a constant raster instead of an empty one)
tmp    <- setValues(rast(r2), 1)          # same grid, all 1s
tmp    <- mask(tmp, ken_v)
n_kenya <- global(!is.na(tmp), "sum", na.rm = TRUE)[[1]]
cat(sprintf("GRDI covers %.1f%% of Kenya's cells (%d of %d)\n",
100 * n_data / n_kenya, n_data, n_kenya))
## ── EDIT THESE ────────────────────────────────────────────────────────────
rwi_csv    <- "data/ken_relative_wealth_index.csv"
gpkg_file  <- "backend/vectorData/ken_county.gpkg"
res_deg    <- 0.0217          # Meta's native cell size (~2.4 km)
out_native <- "data/kenya_rwi_native.tif"
out_smooth <- "data/kenya_rwi_smooth.tif"
# 1. Kenya boundary
ken   <- st_transform(st_read(gpkg_file, quiet = TRUE), 4326)
ken_v <- vect(ken)
bb    <- ext(ken_v)
# 2. RWI points
df <- read.csv(rwi_csv)
names(df) <- tolower(names(df))
pts <- vect(df, geom = c("longitude", "latitude"), crs = "EPSG:4326")
message(sprintf("Loaded %d RWI points", nrow(df)))
# 3. Build an EMPTY GRID over Kenya at Meta's native resolution
grid <- rast(bb, resolution = res_deg, crs = "EPSG:4326")
message(sprintf("Grid: %d x %d cells at %.4f deg (~%.1f km)",
nrow(grid), ncol(grid), res_deg, res_deg * 111))
# 4. RASTERIZE — each point drops into its cell (mean if two share a cell)
r <- rasterize(pts, grid, field = "rwi", fun = "mean")
rm(r)
# 4. RASTERIZE — each point drops into its cell (mean if two share a cell)
r3 <- rasterize(pts, grid, field = "rwi", fun = "mean")
r3 <- mask(r3, ken_v)
cov <- 100 * global(!is.na(r3), "sum", na.rm = TRUE)[[1]] /
global(!is.na(mask(setValues(rast(r), 1), ken_v)), "sum", na.rm = TRUE)[[1]]
cov <- 100 * global(!is.na(r3), "sum", na.rm = TRUE)[[1]] /
global(!is.na(mask(setValues(rast(r3), 1), ken_v)), "sum", na.rm = TRUE)[[1]]
message(sprintf("Native grid coverage: %.1f%% of Kenya", cov))
plot(r3)
