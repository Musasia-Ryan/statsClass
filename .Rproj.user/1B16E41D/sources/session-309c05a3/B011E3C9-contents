#!/usr/bin/env Rscript
# nc_crop_mask_kenya.R
# Load a NetCDF, crop to Kenya's bounding box FIRST (fast, low-memory),
# then mask to Kenya's exact boundary from a county GeoPackage.
#
# Handles multi-time-step files (e.g. daily UV / monthly PM2.5) by averaging
# to a single annual-mean layer — crop happens before the average, so it
# stays cheap even on a global file.
#
# Usage (edit the paths at the top, then run):
#   Rscript nc_crop_mask_kenya.R
#
# Requires: terra, sf   ->  install.packages(c("terra","sf"))

suppressMessages({
  library(terra)
  library(sf)
})

## UV data
nc_file   <- "data/uvddc2024_msr_world.nc"          
gpkg_file <- "backend/vectorData/ken_county.gpkg"
nc_var    <- NA 
out_tif   <- "kenya_uv_2024.tif"


# 1. Kenya boundary + bounding box (in lon/lat)
ken  <- st_read(gpkg_file, quiet = TRUE)
ken  <- st_transform(ken, 4326)
ken_v <- vect(ken)                       
bb   <- ext(ken_v)      
message(sprintf("Kenya bbox: %.2f, %.2f, %.2f, %.2f",
                bb$xmin, bb$xmax, bb$ymin, bb$ymax))

# 2. Open the NetCDF as a (possibly multi-layer) raster
if (is.na(nc_var)) {
  r <- rast(nc_file)                      # terra picks the variable(s)
} else {
  r <- rast(nc_file, subds = nc_var)
}
message(sprintf("Loaded '%s' with %d layer(s)", nc_file, nlyr(r)))

# make sure it carries a lon/lat CRS
if (is.na(crs(r)) || crs(r) == "") crs(r) <- "EPSG:4326"

# 3. CROP to Kenya's bbox FIRST — this is the key speed/memory step
r <- crop(r, bb)
message(sprintf("Cropped to %d x %d cells", nrow(r), ncol(r)))

# 4. Collapse time to an annual mean if there are many layers
if (nlyr(r) > 1) {
  r <- mean(r, na.rm = TRUE)
  message("Averaged multiple layers -> single annual-mean layer")
}

# 5. Mask to Kenya's exact shape (cells outside the border -> NA)
r <- disagg(r, fact = 10, method = "bilinear")
r <- mask(r, ken_v)

plot(r)


# 6. Save + quick look
writeRaster(r, out_tif, overwrite = TRUE)

png("exposure_uv.png", width = 1600, height = 1900, res = 200, bg = "transparent")
par(mar = c(0, 0, 0, 0))                                  # no margins
plot(r, axes = FALSE, legend = FALSE, mar = NA,           # no axes, no colorbar
     col = colorRampPalette(c("#FFFFFF", "#7FA3C9", "#002147"))(100))   # white -> Oxford blue
dev.off()

message(sprintf("Wrote %s", out_tif))

plot(r, main = "Kenya — cropped & masked")
plot(st_geometry(ken), add = TRUE, border = "white", lwd = 0.4)




